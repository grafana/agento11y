# Provider keys. The canned example below does not call a model, but keep these
# here so this file matches the environment shape used by real experiment jobs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_BASE=

# Grafana Cloud ingest plane: generations and scores.
# Copy the API URL, tenant ID, and token from Grafana Cloud AI Observability.
SIGIL_ENDPOINT=https://<your-sigil-api-host>
SIGIL_AUTH_MODE=basic
SIGIL_AUTH_TENANT_ID=<your-tenant-id>
SIGIL_AUTH_TOKEN=<your-cloud-access-policy-token>

# Optional run identity.
RUN_ID=go-experiment-local
GIT_SHA=local

# Optional: customize generated experiment links.
# SIGIL_EXPERIMENT_URL_TEMPLATE={base}/a/grafana-sigil-app/offline-experiments/experiments/{run_id}
